---
import Layout from '@layouts/Layout.astro';

const levels = [
    {
        id: 'fresher',
        label: 'Fresher',
        duration: '0 – 1 Year',
        color: 'green',
        icon: '🌱',
        description: 'Build a strong foundation in networking concepts and earn your first certification.',
        certifications: ['CCNA (Cisco Certified Network Associate)', 'CompTIA Network+', 'Juniper JNCIA'],
        skills: [
            { category: 'Networking Fundamentals', items: ['OSI & TCP/IP Models', 'IP Addressing & Subnetting (IPv4 & IPv6)', 'MAC Addressing & ARP', 'DNS, DHCP, HTTP/S, FTP, SSH'] },
            { category: 'Routing & Switching', items: ['VLANs & 802.1Q Trunking', 'Spanning Tree Protocol (STP/RSTP)', 'EtherChannel / Port-Channel', 'Basic Router Configuration', 'Static & Dynamic Routing (RIP, OSPF basics)'] },
            { category: 'Network Tools', items: ['Wireshark (packet analysis)', 'ping, traceroute, nslookup, netstat', 'Packet Tracer / GNS3 (lab simulator)', 'Basic CLI on Cisco IOS'] },
            { category: 'Operating Systems', items: ['Linux CLI basics (ls, cd, cp, ssh, ifconfig)', 'Windows Server basics', 'File permissions & user management'] },
        ],
        projects: [
            'Build a home lab with GNS3 or Packet Tracer simulating a campus LAN',
            'Configure inter-VLAN routing between 3+ VLANs',
            'Set up DHCP and DNS servers on Linux',
            'Capture and analyze network traffic with Wireshark',
        ],
    },
    {
        id: 'intermediate',
        label: 'Intermediate',
        duration: '2 – 4 Years',
        color: 'yellow',
        icon: '🚀',
        description: 'Deep-dive into advanced protocols, security integration, and network automation.',
        certifications: ['CCNP Enterprise / CCNP Security', 'Juniper JNCIS / JNCIP', 'AWS Advanced Networking Specialty'],
        skills: [
            { category: 'Advanced Routing', items: ['OSPF Multi-Area & Advanced Tuning', 'EIGRP Configuration & Troubleshooting', 'BGP (eBGP/iBGP) fundamentals & attributes', 'Route Redistribution & Policy-Based Routing'] },
            { category: 'WAN & Service Provider', items: ['MPLS & Label Switching', 'SD-WAN (Cisco Viptela, Fortinet)', 'GRE & IPsec VPN Tunnels', 'QoS — DSCP, traffic shaping, policing'] },
            { category: 'Network Security', items: ['Cisco ASA / Palo Alto Firewalls', 'IDS/IPS configuration', 'AAA — RADIUS & TACACS+', 'ACLs & Zone-Based Firewall', 'NAT / PAT'] },
            { category: 'Network Automation', items: ['Python scripting (Netmiko, Paramiko, NAPALM)', 'Ansible for network device automation', 'REST API integration with network devices', 'YANG / NETCONF / RESTCONF basics'] },
            { category: 'Cloud Networking', items: ['AWS VPC, subnets, route tables, security groups', 'Azure VNet & VPN Gateway', 'Hybrid connectivity (Direct Connect, ExpressRoute)', 'Cloud-native load balancers'] },
        ],
        projects: [
            'Automate VLAN provisioning across 10+ switches using Ansible',
            'Configure a full-mesh BGP topology in a lab environment',
            'Set up a site-to-site IPsec VPN between two branch offices',
            'Integrate Palo Alto firewall with AD for user-based policies',
        ],
    },
    {
        id: 'expert',
        label: 'Expert',
        duration: '5+ Years',
        color: 'purple',
        icon: '👑',
        description: 'Lead network architecture, drive automation at scale, and shape organizational network strategy.',
        certifications: ['CCIE Enterprise / CCIE Security / CCIE Data Center', 'Palo Alto PCNSE', 'AWS/Azure Networking Professional'],
        skills: [
            { category: 'Network Architecture & Design', items: ['Campus & Data Center network design', 'Hierarchical & Spine-Leaf architectures', 'Network capacity planning & lifecycle management', 'Disaster recovery & high availability design'] },
            { category: 'Software-Defined Networking (SDN)', items: ['Cisco ACI (Application Centric Infrastructure)', 'VMware NSX-T Data Center', 'OpenFlow & OpenDaylight concepts', 'Intent-Based Networking (Cisco DNA Center)'] },
            { category: 'NFV & Virtualization', items: ['Network Function Virtualization (NFV) with KVM/VMware', 'Virtual routing & switching (CSR1000v, vMX)', 'SR-MPLS & Segment Routing', 'EVPN-VXLAN in Data Center fabrics'] },
            { category: 'Advanced Automation', items: ['Network-as-Code with GitOps', 'Terraform for cloud networking', 'CI/CD pipelines for network config management', 'Custom Python tools for network observability'] },
            { category: 'Enterprise Security Architecture', items: ['Zero Trust Network Architecture (ZTNA)', 'SASE (Secure Access Service Edge)', 'Microsegmentation strategies', 'Network security posture management'] },
        ],
        projects: [
            'Design and implement a Spine-Leaf data center network with EVPN-VXLAN',
            'Build a full GitOps CI/CD pipeline for network configuration management',
            'Architect a Zero Trust network for a 5000+ user enterprise',
            'Deploy Cisco ACI or VMware NSX-T across a production data center',
        ],
    },
];

const jobRoles = [
    { title: 'NOC Engineer', level: 'Fresher', indiaRange: '₹2.5 – 5 LPA', globalRange: '$40K – $65K', description: 'Monitor network infrastructure, handle incidents, and escalate critical issues.' },
    { title: 'Network Administrator', level: 'Fresher–Intermediate', indiaRange: '₹4 – 9 LPA', globalRange: '$55K – $80K', description: 'Day-to-day management of routers, switches, firewalls, and access points.' },
    { title: 'Network Engineer', level: 'Intermediate', indiaRange: '₹8 – 18 LPA', globalRange: '$80K – $115K', description: 'Design, implement, and troubleshoot complex LAN/WAN environments.' },
    { title: 'Network Security Engineer', level: 'Intermediate–Expert', indiaRange: '₹10 – 25 LPA', globalRange: '$95K – $140K', description: 'Harden network perimeters with firewalls, IDS/IPS, VPNs, and threat response.' },
    { title: 'Senior Network Engineer', level: 'Expert', indiaRange: '₹20 – 40 LPA', globalRange: '$130K – $165K', description: 'Lead design projects, mentor juniors, and drive technical standards.' },
    { title: 'Network Architect', level: 'Expert', indiaRange: '₹30 – 55 LPA', globalRange: '$150K – $200K', description: 'Define enterprise network strategy, reference architectures, and technology roadmaps.' },
];

const salaryTable = [
    { level: 'Fresher (0–1 yr)', india: '₹3 – 6 LPA', usa: '$50K – $75K', uk: '£30K – £42K', canada: 'C$55K – C$75K', australia: 'AU$60K – AU$80K' },
    { level: 'Intermediate (2–4 yr)', india: '₹8 – 18 LPA', usa: '$80K – $115K', uk: '£50K – £70K', canada: 'C$85K – C$110K', australia: 'AU$90K – AU$120K' },
    { level: 'Senior (5–8 yr)', india: '₹18 – 35 LPA', usa: '$120K – $155K', uk: '£70K – £95K', canada: 'C$115K – C$145K', australia: 'AU$125K – AU$155K' },
    { level: 'Expert / Architect (8+ yr)', india: '₹30 – 55 LPA', usa: '$150K – $200K', uk: '£95K – £130K', canada: 'C$145K – C$185K', australia: 'AU$155K – AU$200K' },
];
---

<Layout title="Network Engineer Roadmap & Salary Guide" description="Complete Network Engineer career roadmap from Fresher to Expert — CCNA, CCNP, CCIE certifications, job roles, and salary data for India and global markets.">

    <!-- Hero -->
    <section class="relative w-full px-4 py-20 sm:px-6 sm:py-28 bg-base-100">
        <div class="relative mx-auto max-w-5xl text-center">
            <a href="/roadmaps" class="inline-flex items-center gap-1.5 text-sm text-base-content/50 hover:text-primary transition-colors mb-6">
                ← Back to All Roadmaps
            </a>
            <div class="flex justify-center mb-6">
                <div class="w-20 h-20 rounded-3xl bg-blue-500/10 flex items-center justify-center text-4xl">
                    🌐
                </div>
            </div>
            <h1 class="text-4xl font-black sm:text-6xl text-balance">Network Engineer</h1>
            <h2 class="text-xl font-semibold text-primary mt-2">Career Roadmap &amp; Salary Guide 2025</h2>
            <p class="mt-5 text-lg max-w-2xl mx-auto text-base-content/70">
                From CCNA to CCIE — a structured path through networking fundamentals, advanced protocols, security integration, and large-scale automation.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-3">
                <span class="badge badge-lg bg-blue-500/10 text-blue-600 border-blue-200">Routing & Switching</span>
                <span class="badge badge-lg bg-blue-500/10 text-blue-600 border-blue-200">Network Security</span>
                <span class="badge badge-lg bg-blue-500/10 text-blue-600 border-blue-200">SDN & Automation</span>
                <span class="badge badge-lg bg-blue-500/10 text-blue-600 border-blue-200">Cloud Networking</span>
            </div>
        </div>
    </section>

    <!-- Level Tabs Navigation -->
    <section class="w-full px-4 sm:px-6 sticky top-0 z-10 bg-base-100/90 backdrop-blur border-b border-base-200">
        <div class="mx-auto max-w-7xl">
            <div class="flex gap-0 overflow-x-auto">
                {levels.map(level => (
                    <a href={`#${level.id}`}
                        class="flex items-center gap-2 px-5 py-4 text-sm font-bold border-b-2 border-transparent hover:border-primary hover:text-primary transition-colors whitespace-nowrap text-base-content/60">
                        <span>{level.icon}</span>
                        <span>{level.label}</span>
                        <span class="text-xs font-normal opacity-60">({level.duration})</span>
                    </a>
                ))}
                <a href="#job-roles" class="flex items-center gap-2 px-5 py-4 text-sm font-bold border-b-2 border-transparent hover:border-primary hover:text-primary transition-colors whitespace-nowrap text-base-content/60">
                    💼 Job Roles
                </a>
                <a href="#salaries" class="flex items-center gap-2 px-5 py-4 text-sm font-bold border-b-2 border-transparent hover:border-primary hover:text-primary transition-colors whitespace-nowrap text-base-content/60">
                    💰 Salaries
                </a>
            </div>
        </div>
    </section>

    <!-- Roadmap Levels -->
    {levels.map((level) => (
        <section id={level.id} class="w-full px-4 py-16 sm:px-6 sm:py-20 scroll-mt-16" class:list={[level.id === 'intermediate' ? 'bg-base-200/40' : 'bg-base-100']}>
            <div class="mx-auto max-w-7xl">
                <!-- Level Header -->
                <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-10">
                    <div class:list={[
                        'w-16 h-16 rounded-2xl flex items-center justify-center text-3xl flex-shrink-0',
                        level.color === 'green' ? 'bg-green-500/10' : level.color === 'yellow' ? 'bg-yellow-500/10' : 'bg-purple-500/10'
                    ]}>
                        {level.icon}
                    </div>
                    <div>
                        <div class="flex items-center gap-3 flex-wrap">
                            <h2 class="text-2xl sm:text-3xl font-black">{level.label}</h2>
                            <span class:list={[
                                'badge badge-lg font-semibold',
                                level.color === 'green' ? 'badge-success' : level.color === 'yellow' ? 'badge-warning' : 'badge-secondary'
                            ]}>{level.duration}</span>
                        </div>
                        <p class="text-base-content/65 mt-1 max-w-2xl">{level.description}</p>
                    </div>
                </div>

                <!-- Certifications -->
                <div class="mb-8 p-5 rounded-2xl border border-base-200 bg-base-100">
                    <h3 class="font-black text-lg mb-3 flex items-center gap-2">
                        <span>🎓</span> Target Certifications
                    </h3>
                    <div class="flex flex-wrap gap-2">
                        {level.certifications.map(cert => (
                            <span class:list={[
                                'badge badge-lg font-semibold py-3 px-4',
                                level.color === 'green' ? 'bg-green-500/10 text-green-700 border-green-200' :
                                level.color === 'yellow' ? 'bg-yellow-500/10 text-yellow-700 border-yellow-200' :
                                'bg-purple-500/10 text-purple-700 border-purple-200'
                            ]}>{cert}</span>
                        ))}
                    </div>
                </div>

                <!-- Skills Grid -->
                <h3 class="font-black text-xl mb-5 flex items-center gap-2">
                    <span>🛠️</span> Skills to Master
                </h3>
                <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 mb-10">
                    {level.skills.map(skillGroup => (
                        <div class="card bg-base-100 border border-base-200 p-5">
                            <h4 class="font-black text-sm uppercase tracking-wide text-base-content/50 mb-3">{skillGroup.category}</h4>
                            <ul class="space-y-2">
                                {skillGroup.items.map(item => (
                                    <li class="flex items-start gap-2 text-sm">
                                        <span class:list={[
                                            'mt-1 w-1.5 h-1.5 rounded-full flex-shrink-0',
                                            level.color === 'green' ? 'bg-green-500' : level.color === 'yellow' ? 'bg-yellow-500' : 'bg-purple-500'
                                        ]}></span>
                                        <span class="text-base-content/80">{item}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>

                <!-- Projects -->
                <div class="p-6 rounded-2xl border border-dashed border-base-300 bg-base-100/50">
                    <h3 class="font-black text-lg mb-4 flex items-center gap-2">
                        <span>🧪</span> Hands-On Projects
                    </h3>
                    <div class="grid sm:grid-cols-2 gap-3">
                        {level.projects.map((project, i) => (
                            <div class="flex items-start gap-3 p-3 rounded-xl bg-base-100 border border-base-200 text-sm">
                                <span class:list={[
                                    'w-6 h-6 rounded-full flex items-center justify-center text-xs font-black flex-shrink-0 text-white',
                                    level.color === 'green' ? 'bg-green-500' : level.color === 'yellow' ? 'bg-yellow-500' : 'bg-purple-500'
                                ]}>{i + 1}</span>
                                <span class="text-base-content/75">{project}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>
    ))}

    <!-- Job Roles -->
    <section id="job-roles" class="w-full px-4 py-16 sm:px-6 sm:py-20 bg-base-200/40 scroll-mt-16">
        <div class="mx-auto max-w-7xl">
            <h2 class="text-2xl font-black sm:text-4xl mb-3 flex items-center gap-3">
                💼 Job Roles in Network Engineering
            </h2>
            <p class="text-base-content/65 mb-10 max-w-2xl">
                From entry-level NOC roles to senior architect positions — here are the key career titles and what they involve.
            </p>
            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
                {jobRoles.map(role => (
                    <div class="card bg-base-100 border border-base-200 p-6">
                        <div class="flex items-start justify-between gap-2 mb-3">
                            <h3 class="font-black text-base">{role.title}</h3>
                            <span class="badge badge-sm bg-blue-500/10 text-blue-600 border-blue-200 whitespace-nowrap">{role.level}</span>
                        </div>
                        <p class="text-sm text-base-content/65 mb-4">{role.description}</p>
                        <div class="pt-3 border-t border-base-200 space-y-1">
                            <div class="flex justify-between text-sm">
                                <span class="text-base-content/50">India</span>
                                <span class="font-bold">{role.indiaRange}</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-base-content/50">Global (USD)</span>
                                <span class="font-bold">{role.globalRange}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Salary Table -->
    <section id="salaries" class="w-full px-4 py-16 sm:px-6 sm:py-20 scroll-mt-16">
        <div class="mx-auto max-w-7xl">
            <h2 class="text-2xl font-black sm:text-4xl mb-3 flex items-center gap-3">
                💰 Salary Comparison — India vs Global
            </h2>
            <p class="text-base-content/65 mb-10 max-w-2xl">
                Compensation benchmarks across experience levels and geographies (2024–2025 data).
            </p>
            <div class="overflow-x-auto rounded-2xl border border-base-200">
                <table class="table table-lg w-full">
                    <thead class="bg-base-200/60">
                        <tr>
                            <th class="font-black">Experience Level</th>
                            <th class="font-black">India</th>
                            <th class="font-black">USA</th>
                            <th class="font-black">UK</th>
                            <th class="font-black">Canada</th>
                            <th class="font-black">Australia</th>
                        </tr>
                    </thead>
                    <tbody>
                        {salaryTable.map((row, i) => (
                            <tr class:list={[i % 2 === 0 ? '' : 'bg-base-200/20']}>
                                <td class="font-semibold">{row.level}</td>
                                <td class="font-bold text-primary">{row.india}</td>
                                <td>{row.usa}</td>
                                <td>{row.uk}</td>
                                <td>{row.canada}</td>
                                <td>{row.australia}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
            <p class="text-xs text-base-content/40 mt-4">* Salary ranges are indicative, sourced from Glassdoor, LinkedIn Salary, Levels.fyi, Naukri.com, and PayScale (2024–2025). Actual compensation varies by company size, location, and specialization.</p>
        </div>
    </section>

    <!-- CTA -->
    <section class="w-full px-4 py-16 sm:px-6 bg-base-200/40">
        <div class="mx-auto max-w-3xl text-center">
            <h2 class="text-2xl font-black sm:text-3xl mb-4">Ready to Start Your Network Engineering Journey?</h2>
            <p class="text-base-content/65 mb-8">Explore all career roadmaps and find the path that fits you best.</p>
            <a href="/roadmaps" class="btn btn-primary btn-lg">← View All Roadmaps</a>
        </div>
    </section>

</Layout>
