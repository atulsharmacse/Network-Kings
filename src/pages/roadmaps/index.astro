---
import Layout from '@layouts/Layout.astro';
---

<Layout title="Engineer Roadmaps & Salaries" description="Comprehensive career roadmaps for Network, Cybersecurity, Cloud, and DevOps Engineers — with salary insights for India and global markets.">
    <!-- Hero -->
    <section class="relative w-full px-4 py-20 sm:px-6 sm:py-28 text-center bg-base-100">
        <div class="relative mx-auto max-w-5xl">
            <div class="inline-flex items-center gap-2 px-4 py-2 mb-6 text-sm font-semibold rounded-full bg-primary/10 text-primary border border-primary/20">
                Career Pathways 2025
            </div>
            <h1 class="text-4xl font-black sm:text-6xl text-balance leading-tight">
                Engineer Roadmaps &amp;<br />
                <span class="text-primary">Salary Guide</span>
            </h1>
            <p class="mt-6 text-lg sm:text-xl max-w-2xl mx-auto text-base-content/70">
                Step-by-step career roadmaps for Fresher, Intermediate, and Expert levels — with real salary data for India and global markets.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-3 text-sm text-base-content/60">
                <span class="badge badge-outline badge-lg">Network Engineering</span>
                <span class="badge badge-outline badge-lg">Cybersecurity</span>
                <span class="badge badge-outline badge-lg">Cloud Engineering</span>
                <span class="badge badge-outline badge-lg">DevOps</span>
            </div>
        </div>
    </section>

    <!-- Career Cards -->
    <section class="w-full px-4 py-16 sm:px-6 bg-base-200/40">
        <div class="mx-auto max-w-7xl">
            <h2 class="text-2xl font-black sm:text-4xl text-center mb-12">Choose Your Career Path</h2>
            <div class="grid gap-8 md:grid-cols-2">

                <!-- Network Engineer -->
                <a href="/roadmaps/network-engineer" class="group card bg-base-100 border border-base-200 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1">
                    <div class="card-body p-8">
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 rounded-2xl bg-blue-500/10 flex items-center justify-center text-2xl flex-shrink-0">
                                🌐
                            </div>
                            <div class="flex-1">
                                <h3 class="card-title text-xl font-black group-hover:text-primary transition-colors">Network Engineer</h3>
                                <p class="text-base-content/65 mt-2 text-sm leading-relaxed">
                                    Design, build, and manage network infrastructure. From CCNA to CCIE — master routing, switching, security, and network automation.
                                </p>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <span class="badge badge-sm bg-blue-500/10 text-blue-600 border-blue-200">CCNA → CCIE</span>
                                    <span class="badge badge-sm bg-blue-500/10 text-blue-600 border-blue-200">Routing & Switching</span>
                                    <span class="badge badge-sm bg-blue-500/10 text-blue-600 border-blue-200">Network Automation</span>
                                </div>
                                <div class="mt-5 pt-4 border-t border-base-200 grid grid-cols-2 gap-3 text-sm">
                                    <div>
                                        <div class="text-base-content/50 text-xs uppercase tracking-wide font-semibold">India Salary</div>
                                        <div class="font-bold text-base-content mt-1">₹3 – 45 LPA</div>
                                    </div>
                                    <div>
                                        <div class="text-base-content/50 text-xs uppercase tracking-wide font-semibold">Global Salary</div>
                                        <div class="font-bold text-base-content mt-1">$50K – $180K</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>

                <!-- Cybersecurity Engineer -->
                <a href="/roadmaps/cybersecurity-engineer" class="group card bg-base-100 border border-base-200 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1">
                    <div class="card-body p-8">
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 rounded-2xl bg-red-500/10 flex items-center justify-center text-2xl flex-shrink-0">
                                🔐
                            </div>
                            <div class="flex-1">
                                <h3 class="card-title text-xl font-black group-hover:text-primary transition-colors">Cybersecurity Engineer</h3>
                                <p class="text-base-content/65 mt-2 text-sm leading-relaxed">
                                    Protect systems, networks, and data from cyber threats. Progress from Security+ to CISSP — ethical hacking, SOC analysis, and security architecture.
                                </p>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <span class="badge badge-sm bg-red-500/10 text-red-600 border-red-200">Security+ → CISSP</span>
                                    <span class="badge badge-sm bg-red-500/10 text-red-600 border-red-200">Ethical Hacking</span>
                                    <span class="badge badge-sm bg-red-500/10 text-red-600 border-red-200">SOC / SIEM</span>
                                </div>
                                <div class="mt-5 pt-4 border-t border-base-200 grid grid-cols-2 gap-3 text-sm">
                                    <div>
                                        <div class="text-base-content/50 text-xs uppercase tracking-wide font-semibold">India Salary</div>
                                        <div class="font-bold text-base-content mt-1">₹4 – 60 LPA</div>
                                    </div>
                                    <div>
                                        <div class="text-base-content/50 text-xs uppercase tracking-wide font-semibold">Global Salary</div>
                                        <div class="font-bold text-base-content mt-1">$60K – $250K</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>

                <!-- Cloud Engineer -->
                <a href="/roadmaps/cloud-engineer" class="group card bg-base-100 border border-base-200 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1">
                    <div class="card-body p-8">
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 rounded-2xl bg-sky-500/10 flex items-center justify-center text-2xl flex-shrink-0">
                                ☁️
                            </div>
                            <div class="flex-1">
                                <h3 class="card-title text-xl font-black group-hover:text-primary transition-colors">Cloud Engineer</h3>
                                <p class="text-base-content/65 mt-2 text-sm leading-relaxed">
                                    Build and manage cloud infrastructure on AWS, Azure, and GCP. From Cloud Practitioner to Solutions Architect Professional — IaC, Kubernetes, and multi-cloud.
                                </p>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <span class="badge badge-sm bg-sky-500/10 text-sky-600 border-sky-200">AWS / Azure / GCP</span>
                                    <span class="badge badge-sm bg-sky-500/10 text-sky-600 border-sky-200">Terraform / IaC</span>
                                    <span class="badge badge-sm bg-sky-500/10 text-sky-600 border-sky-200">Kubernetes</span>
                                </div>
                                <div class="mt-5 pt-4 border-t border-base-200 grid grid-cols-2 gap-3 text-sm">
                                    <div>
                                        <div class="text-base-content/50 text-xs uppercase tracking-wide font-semibold">India Salary</div>
                                        <div class="font-bold text-base-content mt-1">₹4 – 70 LPA</div>
                                    </div>
                                    <div>
                                        <div class="text-base-content/50 text-xs uppercase tracking-wide font-semibold">Global Salary</div>
                                        <div class="font-bold text-base-content mt-1">$70K – $250K</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>

                <!-- DevOps Engineer -->
                <a href="/roadmaps/devops-engineer" class="group card bg-base-100 border border-base-200 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1">
                    <div class="card-body p-8">
                        <div class="flex items-start gap-4">
                            <div class="w-14 h-14 rounded-2xl bg-green-500/10 flex items-center justify-center text-2xl flex-shrink-0">
                                ⚙️
                            </div>
                            <div class="flex-1">
                                <h3 class="card-title text-xl font-black group-hover:text-primary transition-colors">DevOps Engineer</h3>
                                <p class="text-base-content/65 mt-2 text-sm leading-relaxed">
                                    Bridge development and operations with automation, CI/CD, and cloud platforms. From Git and Docker to GitOps, Platform Engineering, and SRE practices.
                                </p>
                                <div class="mt-4 flex flex-wrap gap-2">
                                    <span class="badge badge-sm bg-green-500/10 text-green-600 border-green-200">CI/CD Pipelines</span>
                                    <span class="badge badge-sm bg-green-500/10 text-green-600 border-green-200">Docker / K8s</span>
                                    <span class="badge badge-sm bg-green-500/10 text-green-600 border-green-200">GitOps / SRE</span>
                                </div>
                                <div class="mt-5 pt-4 border-t border-base-200 grid grid-cols-2 gap-3 text-sm">
                                    <div>
                                        <div class="text-base-content/50 text-xs uppercase tracking-wide font-semibold">India Salary</div>
                                        <div class="font-bold text-base-content mt-1">₹4 – 60 LPA</div>
                                    </div>
                                    <div>
                                        <div class="text-base-content/50 text-xs uppercase tracking-wide font-semibold">Global Salary</div>
                                        <div class="font-bold text-base-content mt-1">$75K – $220K</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>

            </div>
        </div>
    </section>

    <!-- Why These Careers -->
    <section class="w-full px-4 py-16 sm:px-6">
        <div class="mx-auto max-w-7xl">
            <h2 class="text-2xl font-black sm:text-4xl text-center mb-4">Why These Careers?</h2>
            <p class="text-center text-base-content/65 max-w-2xl mx-auto mb-12">
                The demand for infrastructure, security, cloud, and automation talent is at an all-time high — and growing.
            </p>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                <div class="card bg-base-100 border border-base-200 text-center p-6">
                    <div class="text-4xl font-black text-primary mb-2">40%</div>
                    <div class="text-sm text-base-content/70">Job growth in cloud & DevOps roles projected by 2028 (BLS)</div>
                </div>
                <div class="card bg-base-100 border border-base-200 text-center p-6">
                    <div class="text-4xl font-black text-primary mb-2">3.5M</div>
                    <div class="text-sm text-base-content/70">Unfilled cybersecurity jobs globally in 2025 (ISC²)</div>
                </div>
                <div class="card bg-base-100 border border-base-200 text-center p-6">
                    <div class="text-4xl font-black text-primary mb-2">94%</div>
                    <div class="text-sm text-base-content/70">Enterprises using cloud services — driving cloud talent demand</div>
                </div>
                <div class="card bg-base-100 border border-base-200 text-center p-6">
                    <div class="text-4xl font-black text-primary mb-2">₹70L+</div>
                    <div class="text-sm text-base-content/70">Average expert cloud/security salary in top Indian tech companies</div>
                </div>
            </div>
        </div>
    </section>
</Layout>
