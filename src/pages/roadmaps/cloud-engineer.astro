---
import Layout from '@layouts/Layout.astro';

const levels = [
    {
        id: 'fresher',
        label: 'Fresher',
        duration: '0 – 1 Year',
        color: 'green',
        icon: '🌱',
        description: 'Understand cloud fundamentals, explore the big three providers, and earn your first certification.',
        certifications: ['AWS Cloud Practitioner (CLF-C02)', 'Microsoft Azure Fundamentals (AZ-900)', 'Google Cloud Digital Leader / ACE', 'HashiCorp Terraform Associate'],
        skills: [
            { category: 'Cloud Fundamentals', items: ['IaaS, PaaS, SaaS & FaaS models', 'Public, Private, Hybrid & Multi-cloud', 'Virtualization & hypervisors (VMware, KVM)', 'Shared responsibility model', 'High availability & fault tolerance concepts'] },
            { category: 'Core AWS / Azure / GCP Services', items: ['Compute: EC2, Azure VMs, Google Compute Engine', 'Storage: S3, Azure Blob, GCS', 'Networking: VPC, VNet, VPC (GCP)', 'Databases: RDS, Azure SQL, Cloud SQL', 'IAM — users, roles, policies, groups'] },
            { category: 'Linux & Scripting Basics', items: ['Linux CLI navigation & file management', 'Bash scripting fundamentals', 'Python basics (lists, loops, functions, requests)', 'SSH key management', 'Environment variables & dotfiles'] },
            { category: 'Networking Basics', items: ['CIDR notation & subnetting', 'Load balancers (ALB, NLB, Azure LB)', 'Security groups & network ACLs', 'Route tables & internet gateways', 'DNS resolution in cloud environments'] },
        ],
        projects: [
            'Deploy a static website on S3/Azure Blob with custom domain & HTTPS via CloudFront/CDN',
            'Launch a Linux VM, configure SSH access, and install a web server (Nginx/Apache)',
            'Create IAM users with least-privilege permissions using the console and CLI',
            'Set up a basic VPC with public/private subnets, NAT Gateway, and internet gateway',
        ],
    },
    {
        id: 'intermediate',
        label: 'Intermediate',
        duration: '2 – 4 Years',
        color: 'yellow',
        icon: '🚀',
        description: 'Automate infrastructure, build CI/CD pipelines, and architect scalable cloud solutions.',
        certifications: ['AWS Solutions Architect Associate (SAA-C03)', 'AWS SysOps Administrator Associate', 'Microsoft Azure Administrator (AZ-104)', 'Certified Kubernetes Administrator (CKA)'],
        skills: [
            { category: 'Infrastructure as Code (IaC)', items: ['Terraform — providers, modules, state, workspaces', 'AWS CloudFormation & CDK', 'Azure Resource Manager (ARM) templates / Bicep', 'Pulumi basics', 'IaC best practices — DRY, remote state, plan/apply'] },
            { category: 'Containers & Orchestration', items: ['Docker — images, containers, volumes, networking', 'Docker Compose for local multi-service apps', 'Kubernetes core objects (Pods, Deployments, Services, Ingress)', 'Helm charts for application deployment', 'EKS / AKS / GKE managed Kubernetes'] },
            { category: 'CI/CD & DevOps Practices', items: ['GitHub Actions, GitLab CI, Jenkins pipelines', 'Artifact management (ECR, Azure Container Registry)', 'Blue-green & canary deployments', 'Infrastructure testing (Terratest, checkov)', 'GitOps concepts (ArgoCD intro)'] },
            { category: 'Monitoring & Cost Optimization', items: ['CloudWatch, Azure Monitor, Google Cloud Monitoring', 'Prometheus + Grafana dashboards', 'AWS Cost Explorer & Budgets', 'Reserved Instances & Savings Plans', 'Rightsizing & auto-scaling strategies'] },
        ],
        projects: [
            'Build a 3-tier web application (ALB + EC2 ASG + RDS) fully provisioned with Terraform',
            'Containerize a Node.js/Python app and deploy to EKS/AKS with Helm',
            'Create a CI/CD pipeline with GitHub Actions that builds, tests, and deploys to AWS',
            'Set up cross-account AWS Organizations structure with SCP policies',
        ],
    },
    {
        id: 'expert',
        label: 'Expert',
        duration: '5+ Years',
        color: 'purple',
        icon: '👑',
        description: 'Design multi-cloud architectures, drive FinOps, lead SRE practices, and mentor engineering teams.',
        certifications: ['AWS Solutions Architect Professional (SAP-C02)', 'AWS DevOps Engineer Professional', 'Google Professional Cloud Architect', 'Certified Kubernetes Security Specialist (CKS)'],
        skills: [
            { category: 'Advanced Architecture Patterns', items: ['Event-driven architecture (SQS, SNS, EventBridge, Pub/Sub)', 'Microservices vs monolith trade-offs', 'Service mesh — Istio, Linkerd', 'Serverless — AWS Lambda, Azure Functions, Cloud Run', 'CQRS, Saga pattern, outbox pattern'] },
            { category: 'Multi-Cloud & Hybrid', items: ['AWS Transit Gateway & Azure Virtual WAN', 'Google Anthos & Azure Arc for hybrid management', 'Cross-cloud networking (VPN/peering between providers)', 'Multi-cloud secret management (HashiCorp Vault)', 'Data sovereignty & compliance across clouds'] },
            { category: 'Site Reliability Engineering (SRE)', items: ['SLIs, SLOs, SLAs & error budgets', 'Chaos engineering (AWS Fault Injection Simulator, Chaos Monkey)', 'Distributed tracing (Jaeger, AWS X-Ray)', 'Incident management & blameless post-mortems', 'Toil automation & runbook-as-code'] },
            { category: 'FinOps & Cloud Governance', items: ['FinOps Foundation principles & maturity model', 'Tagging strategies & cost allocation', 'AWS Control Tower & Landing Zone', 'Azure Policy & Blueprints', 'Cloud security posture management (CSPM — Prisma Cloud, Wiz)'] },
        ],
        projects: [
            'Architect a globally distributed application across AWS + Azure with a common Terraform codebase',
            'Implement a full SRE observability stack (metrics, logs, traces) with defined SLO dashboards',
            'Build a multi-account AWS Landing Zone using Control Tower + customizations',
            'Run a chaos engineering gameday and produce a resilience improvement report',
        ],
    },
];

const jobRoles = [
    { title: 'Cloud Support Associate', level: 'Fresher', indiaRange: '₹3.5 – 7 LPA', globalRange: '$50K – $75K', description: 'Help customers troubleshoot cloud services and provide technical guidance.' },
    { title: 'Cloud Engineer', level: 'Fresher–Intermediate', indiaRange: '₹5 – 14 LPA', globalRange: '$75K – $110K', description: 'Provision, manage, and automate cloud infrastructure for development teams.' },
    { title: 'DevOps / Cloud DevOps Engineer', level: 'Intermediate', indiaRange: '₹10 – 22 LPA', globalRange: '$100K – $145K', description: 'Build and maintain CI/CD pipelines, IaC, and container platforms on cloud.' },
    { title: 'Cloud Security Engineer', level: 'Intermediate–Expert', indiaRange: '₹14 – 30 LPA', globalRange: '$120K – $165K', description: 'Secure cloud workloads, implement CSPM, and ensure compliance with frameworks.' },
    { title: 'Site Reliability Engineer (SRE)', level: 'Intermediate–Expert', indiaRange: '₹15 – 35 LPA', globalRange: '$130K – $180K', description: 'Ensure service reliability with SLOs, automation, and incident response.' },
    { title: 'FinOps Engineer', level: 'Intermediate–Expert', indiaRange: '₹14 – 28 LPA', globalRange: '$110K – $155K', description: 'Optimize cloud spend through cost governance, tagging, and reservation strategies.' },
    { title: 'Cloud Solutions Architect', level: 'Expert', indiaRange: '₹25 – 50 LPA', globalRange: '$150K – $210K', description: 'Design scalable, secure, and cost-effective cloud architectures for large enterprises.' },
    { title: 'Principal / Staff Cloud Engineer', level: 'Expert', indiaRange: '₹35 – 70 LPA', globalRange: '$180K – $280K', description: 'Technical leader setting cloud strategy, standards, and mentoring across engineering teams.' },
];

const salaryTable = [
    { level: 'Fresher (0–1 yr)', india: '₹4 – 8 LPA', usa: '$65K – $95K', uk: '£38K – £55K', canada: 'C$65K – C$90K', australia: 'AU$70K – AU$95K' },
    { level: 'Intermediate (2–4 yr)', india: '₹10 – 25 LPA', usa: '$100K – $150K', uk: '£65K – £90K', canada: 'C$95K – C$135K', australia: 'AU$100K – AU$140K' },
    { level: 'Senior (5–8 yr)', india: '₹22 – 45 LPA', usa: '$145K – $195K', uk: '£90K – £125K', canada: 'C$135K – C$175K', australia: 'AU$140K – AU$185K' },
    { level: 'Expert / Architect (8+ yr)', india: '₹40 – 75 LPA', usa: '$180K – $270K', uk: '£120K – £170K', canada: 'C$170K – C$230K', australia: 'AU$180K – AU$250K' },
];
---

<Layout title="Cloud Engineer Roadmap & Salary Guide" description="Complete Cloud Engineer career roadmap from Fresher to Expert — AWS, Azure, GCP certifications, Kubernetes, Terraform, SRE, and salary data for India and global markets.">

    <!-- Hero -->
    <section class="relative w-full px-4 py-20 sm:px-6 sm:py-28 bg-base-100">
        <div class="relative mx-auto max-w-5xl text-center">
            <a href="/roadmaps" class="inline-flex items-center gap-1.5 text-sm text-base-content/50 hover:text-primary transition-colors mb-6">
                ← Back to All Roadmaps
            </a>
            <div class="flex justify-center mb-6">
                <div class="w-20 h-20 rounded-3xl bg-sky-500/10 flex items-center justify-center text-4xl">
                    ☁️
                </div>
            </div>
            <h1 class="text-4xl font-black sm:text-6xl text-balance">Cloud Engineer</h1>
            <h2 class="text-xl font-semibold text-primary mt-2">Career Roadmap &amp; Salary Guide 2025</h2>
            <p class="mt-5 text-lg max-w-2xl mx-auto text-base-content/70">
                From Cloud Practitioner to Solutions Architect Professional — master AWS, Azure, and GCP, build scalable infrastructure with Terraform and Kubernetes, and lead cloud transformations.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-3">
                <span class="badge badge-lg bg-sky-500/10 text-sky-600 border-sky-200">AWS / Azure / GCP</span>
                <span class="badge badge-lg bg-sky-500/10 text-sky-600 border-sky-200">Terraform / IaC</span>
                <span class="badge badge-lg bg-sky-500/10 text-sky-600 border-sky-200">Kubernetes & EKS</span>
                <span class="badge badge-lg bg-sky-500/10 text-sky-600 border-sky-200">SRE & FinOps</span>
            </div>
        </div>
    </section>

    <!-- Level Tabs Navigation -->
    <section class="w-full px-4 sm:px-6 sticky top-0 z-10 bg-base-100/90 backdrop-blur border-b border-base-200">
        <div class="mx-auto max-w-7xl">
            <div class="flex gap-0 overflow-x-auto">
                {levels.map(level => (
                    <a href={`#${level.id}`}
                        class="flex items-center gap-2 px-5 py-4 text-sm font-bold border-b-2 border-transparent hover:border-primary hover:text-primary transition-colors whitespace-nowrap text-base-content/60">
                        <span>{level.icon}</span>
                        <span>{level.label}</span>
                        <span class="text-xs font-normal opacity-60">({level.duration})</span>
                    </a>
                ))}
                <a href="#job-roles" class="flex items-center gap-2 px-5 py-4 text-sm font-bold border-b-2 border-transparent hover:border-primary hover:text-primary transition-colors whitespace-nowrap text-base-content/60">
                    💼 Job Roles
                </a>
                <a href="#salaries" class="flex items-center gap-2 px-5 py-4 text-sm font-bold border-b-2 border-transparent hover:border-primary hover:text-primary transition-colors whitespace-nowrap text-base-content/60">
                    💰 Salaries
                </a>
            </div>
        </div>
    </section>

    <!-- Roadmap Levels -->
    {levels.map((level) => (
        <section id={level.id} class="w-full px-4 py-16 sm:px-6 sm:py-20 scroll-mt-16" class:list={[level.id === 'intermediate' ? 'bg-base-200/40' : 'bg-base-100']}>
            <div class="mx-auto max-w-7xl">
                <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-10">
                    <div class:list={[
                        'w-16 h-16 rounded-2xl flex items-center justify-center text-3xl flex-shrink-0',
                        level.color === 'green' ? 'bg-green-500/10' : level.color === 'yellow' ? 'bg-yellow-500/10' : 'bg-purple-500/10'
                    ]}>
                        {level.icon}
                    </div>
                    <div>
                        <div class="flex items-center gap-3 flex-wrap">
                            <h2 class="text-2xl sm:text-3xl font-black">{level.label}</h2>
                            <span class:list={[
                                'badge badge-lg font-semibold',
                                level.color === 'green' ? 'badge-success' : level.color === 'yellow' ? 'badge-warning' : 'badge-secondary'
                            ]}>{level.duration}</span>
                        </div>
                        <p class="text-base-content/65 mt-1 max-w-2xl">{level.description}</p>
                    </div>
                </div>

                <div class="mb-8 p-5 rounded-2xl border border-base-200 bg-base-100">
                    <h3 class="font-black text-lg mb-3 flex items-center gap-2">
                        <span>🎓</span> Target Certifications
                    </h3>
                    <div class="flex flex-wrap gap-2">
                        {level.certifications.map(cert => (
                            <span class:list={[
                                'badge badge-lg font-semibold py-3 px-4',
                                level.color === 'green' ? 'bg-green-500/10 text-green-700 border-green-200' :
                                level.color === 'yellow' ? 'bg-yellow-500/10 text-yellow-700 border-yellow-200' :
                                'bg-purple-500/10 text-purple-700 border-purple-200'
                            ]}>{cert}</span>
                        ))}
                    </div>
                </div>

                <h3 class="font-black text-xl mb-5 flex items-center gap-2">
                    <span>🛠️</span> Skills to Master
                </h3>
                <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 mb-10">
                    {level.skills.map(skillGroup => (
                        <div class="card bg-base-100 border border-base-200 p-5">
                            <h4 class="font-black text-sm uppercase tracking-wide text-base-content/50 mb-3">{skillGroup.category}</h4>
                            <ul class="space-y-2">
                                {skillGroup.items.map(item => (
                                    <li class="flex items-start gap-2 text-sm">
                                        <span class:list={[
                                            'mt-1 w-1.5 h-1.5 rounded-full flex-shrink-0',
                                            level.color === 'green' ? 'bg-green-500' : level.color === 'yellow' ? 'bg-yellow-500' : 'bg-purple-500'
                                        ]}></span>
                                        <span class="text-base-content/80">{item}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>

                <div class="p-6 rounded-2xl border border-dashed border-base-300 bg-base-100/50">
                    <h3 class="font-black text-lg mb-4 flex items-center gap-2">
                        <span>🧪</span> Hands-On Projects
                    </h3>
                    <div class="grid sm:grid-cols-2 gap-3">
                        {level.projects.map((project, i) => (
                            <div class="flex items-start gap-3 p-3 rounded-xl bg-base-100 border border-base-200 text-sm">
                                <span class:list={[
                                    'w-6 h-6 rounded-full flex items-center justify-center text-xs font-black flex-shrink-0 text-white',
                                    level.color === 'green' ? 'bg-green-500' : level.color === 'yellow' ? 'bg-yellow-500' : 'bg-purple-500'
                                ]}>{i + 1}</span>
                                <span class="text-base-content/75">{project}</span>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>
    ))}

    <!-- Job Roles -->
    <section id="job-roles" class="w-full px-4 py-16 sm:px-6 sm:py-20 bg-base-200/40 scroll-mt-16">
        <div class="mx-auto max-w-7xl">
            <h2 class="text-2xl font-black sm:text-4xl mb-3">💼 Job Roles in Cloud Engineering</h2>
            <p class="text-base-content/65 mb-10 max-w-2xl">
                Cloud roles span infrastructure, security, reliability, and cost optimization — often with premium compensation.
            </p>
            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
                {jobRoles.map(role => (
                    <div class="card bg-base-100 border border-base-200 p-6">
                        <div class="flex items-start justify-between gap-2 mb-3">
                            <h3 class="font-black text-base">{role.title}</h3>
                            <span class="badge badge-sm bg-sky-500/10 text-sky-600 border-sky-200 whitespace-nowrap">{role.level}</span>
                        </div>
                        <p class="text-sm text-base-content/65 mb-4">{role.description}</p>
                        <div class="pt-3 border-t border-base-200 space-y-1">
                            <div class="flex justify-between text-sm">
                                <span class="text-base-content/50">India</span>
                                <span class="font-bold">{role.indiaRange}</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-base-content/50">Global (USD)</span>
                                <span class="font-bold">{role.globalRange}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Salary Table -->
    <section id="salaries" class="w-full px-4 py-16 sm:px-6 sm:py-20 scroll-mt-16">
        <div class="mx-auto max-w-7xl">
            <h2 class="text-2xl font-black sm:text-4xl mb-3">💰 Salary Comparison — India vs Global</h2>
            <p class="text-base-content/65 mb-10 max-w-2xl">
                Cloud engineering commands among the highest salaries in tech — 94% of enterprises use cloud, creating massive demand.
            </p>
            <div class="overflow-x-auto rounded-2xl border border-base-200">
                <table class="table table-lg w-full">
                    <thead class="bg-base-200/60">
                        <tr>
                            <th class="font-black">Experience Level</th>
                            <th class="font-black">India</th>
                            <th class="font-black">USA</th>
                            <th class="font-black">UK</th>
                            <th class="font-black">Canada</th>
                            <th class="font-black">Australia</th>
                        </tr>
                    </thead>
                    <tbody>
                        {salaryTable.map((row, i) => (
                            <tr class:list={[i % 2 === 0 ? '' : 'bg-base-200/20']}>
                                <td class="font-semibold">{row.level}</td>
                                <td class="font-bold text-primary">{row.india}</td>
                                <td>{row.usa}</td>
                                <td>{row.uk}</td>
                                <td>{row.canada}</td>
                                <td>{row.australia}</td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
            <p class="text-xs text-base-content/40 mt-4">* Salary ranges are indicative, sourced from Glassdoor, Levels.fyi, AWS/Azure salary surveys, LinkedIn Salary, and Naukri.com (2024–2025).</p>
        </div>
    </section>

    <!-- CTA -->
    <section class="w-full px-4 py-16 sm:px-6 bg-base-200/40">
        <div class="mx-auto max-w-3xl text-center">
            <h2 class="text-2xl font-black sm:text-3xl mb-4">Ready to Build the Infrastructure of Tomorrow?</h2>
            <p class="text-base-content/65 mb-8">Explore all career roadmaps and find the path that fits you best.</p>
            <a href="/roadmaps" class="btn btn-primary btn-lg">← View All Roadmaps</a>
        </div>
    </section>

</Layout>
