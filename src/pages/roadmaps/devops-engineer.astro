---
import RoadmapPage from '@components/RoadmapPage.astro';
import type { RoadmapLevel, RoadmapJobRole, RoadmapSalaryRow } from '@components/RoadmapPage.astro';

const levels: RoadmapLevel[] = [
    {
        id: 'fresher',
        label: 'Fresher',
        duration: '0 – 1 Year',
        color: 'green',
        icon: '🌱',
        description: 'Build the foundations of DevOps — Linux, version control, scripting, and the cloud basics.',
        certifications: ['AWS Cloud Practitioner', 'Linux Foundation Certified Sysadmin (LFCS)', 'HashiCorp Terraform Associate', 'Docker Certified Associate (DCA) — intro prep'],
        skills: [
            { category: 'Linux & Shell', items: ['Linux file system & permissions', 'Process management (ps, top, kill, systemctl)', 'Shell scripting (Bash) — loops, conditionals, functions', 'Cron jobs & task scheduling', 'Package management (apt, yum, dnf)'] },
            { category: 'Version Control', items: ['Git fundamentals (init, clone, add, commit, push, pull)', 'Branching strategies (Git Flow, trunk-based)', 'Pull requests & code review workflows', 'GitHub / GitLab essentials', 'Merge conflict resolution'] },
            { category: 'Containers Basics', items: ['What is containerization vs virtualization?', 'Docker images, containers, volumes & networks', 'Writing Dockerfiles', 'Docker Compose for multi-service apps', 'Container registries (Docker Hub, ECR, GHCR)'] },
            { category: 'Cloud & Scripting', items: ['AWS basics — EC2, S3, VPC, IAM, RDS', 'Python scripting (boto3 for AWS automation)', 'Basic CI/CD concepts (build → test → deploy)', 'YAML syntax for configuration files', 'Agile / Scrum methodology basics'] },
        ],
        projects: [
            'Containerize a Node.js or Python Flask app and publish the image to Docker Hub',
            'Write a Bash script that automates system health checks (CPU, memory, disk)',
            'Set up a GitHub repository with branch protection rules and a basic PR workflow',
            'Deploy a simple app on AWS EC2 using the AWS CLI and user data scripts',
        ],
    },
    {
        id: 'intermediate',
        label: 'Intermediate',
        duration: '2 – 4 Years',
        color: 'yellow',
        icon: '🚀',
        description: 'Automate everything — CI/CD pipelines, IaC, container orchestration, and observability stacks.',
        certifications: ['AWS DevOps Engineer Professional (prep track)', 'Certified Kubernetes Administrator (CKA)', 'HashiCorp Terraform Associate / Professional', 'Jenkins Engineer Certification'],
        skills: [
            { category: 'CI/CD Pipelines', items: ['GitHub Actions — workflows, secrets, matrix builds', 'Jenkins — pipelines, shared libraries, agents', 'GitLab CI/CD — stages, artifacts, environments', 'SonarQube for code quality gates', 'Nexus / JFrog Artifactory for artifact storage'] },
            { category: 'Infrastructure as Code', items: ['Terraform — modules, remote state (S3 + DynamoDB), workspaces', 'Ansible — playbooks, roles, inventory, vault', 'AWS CloudFormation / CDK', 'Packer for golden machine images', 'Policy-as-code (Open Policy Agent, Sentinel)'] },
            { category: 'Kubernetes Deep Dive', items: ['Deployments, StatefulSets, DaemonSets, Jobs & CronJobs', 'ConfigMaps & Secrets management', 'Persistent volumes (PVC / PV / StorageClass)', 'RBAC, NetworkPolicies & Pod Security Standards', 'Horizontal Pod Autoscaler (HPA) & Cluster Autoscaler'] },
            { category: 'Observability', items: ['Prometheus — scraping, PromQL, alerting rules', 'Grafana — dashboards & alert notifications', 'ELK / EFK Stack (Elasticsearch, Logstash/Fluentd, Kibana)', 'Distributed tracing — Jaeger / Zipkin', 'AWS CloudWatch & X-Ray integration'] },
        ],
        projects: [
            'Build a full CI/CD pipeline: GitHub Actions → Docker build → push to ECR → deploy to EKS',
            'Write a Terraform module library for a 3-tier AWS application (VPC, ALB, ECS/EKS, RDS)',
            'Set up a full observability stack: Prometheus + Grafana + Loki + Tempo on Kubernetes',
            'Implement Ansible playbooks to configure 20+ servers with idempotent roles',
        ],
    },
    {
        id: 'expert',
        label: 'Expert',
        duration: '5+ Years',
        color: 'purple',
        icon: '👑',
        description: 'Drive platform engineering, GitOps, chaos engineering, and shape DevOps culture across engineering orgs.',
        certifications: ['AWS DevOps Engineer Professional', 'Certified Kubernetes Security Specialist (CKS)', 'ArgoCD & Flux GitOps certifications', 'Platform Engineering — CNCF Certifications'],
        skills: [
            { category: 'GitOps & Platform Engineering', items: ['ArgoCD — ApplicationSets, App of Apps pattern', 'Flux v2 — Kustomize controller, Helm releases, image automation', 'Backstage.io developer portal setup', 'Internal Developer Platform (IDP) design', 'Golden path templates for service creation'] },
            { category: 'Advanced Kubernetes', items: ['Custom Resource Definitions (CRDs) & Operators', 'Service mesh with Istio — mTLS, traffic splitting, observability', 'Karpenter for intelligent node provisioning', 'Multi-cluster management (Cluster API, ArgoCD Hub-Spoke)', 'Kubernetes cost optimization (Kubecost, KEDA)'] },
            { category: 'DevSecOps', items: ['SAST tools (SonarQube, Semgrep) in pipelines', 'DAST with OWASP ZAP / Burp Suite in CI', 'Container image scanning (Trivy, Snyk, Grype)', 'Supply chain security (Sigstore, SLSA framework)', 'Secret scanning & rotation (HashiCorp Vault, AWS Secrets Manager)'] },
            { category: 'Chaos Engineering & SRE', items: ['AWS Fault Injection Simulator (FIS)', 'Chaos Monkey & Chaos Mesh for Kubernetes', 'Error budget definition and enforcement', 'Runbook automation (Ansible, Python scripts)', 'Architecture for 99.99%+ availability (multi-AZ, multi-region)'] },
        ],
        projects: [
            'Build an Internal Developer Platform (IDP) using Backstage.io with templates for 5+ service types',
            'Implement a full GitOps workflow with ArgoCD ApplicationSets across dev/staging/prod clusters',
            'Integrate DevSecOps: Trivy image scanning + SAST + OPA policies as CI/CD gates',
            'Run a chaos engineering gameday using AWS FIS and document resilience improvements',
        ],
    },
];

const jobRoles: RoadmapJobRole[] = [
    { title: 'Build & Release Engineer', level: 'Fresher', indiaRange: '₹3.5 – 7 LPA', globalRange: '$55K – $80K', description: 'Manage build systems, version control, and release pipelines for software teams.' },
    { title: 'Junior DevOps Engineer', level: 'Fresher–Intermediate', indiaRange: '₹5 – 10 LPA', globalRange: '$70K – $100K', description: 'Support CI/CD pipelines, container deployments, and cloud infrastructure provisioning.' },
    { title: 'DevOps Engineer', level: 'Intermediate', indiaRange: '₹10 – 22 LPA', globalRange: '$100K – $145K', description: 'Own end-to-end automation from code commit to production deployment across cloud environments.' },
    { title: 'Site Reliability Engineer (SRE)', level: 'Intermediate–Expert', indiaRange: '₹14 – 35 LPA', globalRange: '$130K – $185K', description: 'Ensure service reliability with SLOs, error budgets, and automated incident response.' },
    { title: 'Platform Engineer', level: 'Intermediate–Expert', indiaRange: '₹15 – 32 LPA', globalRange: '$130K – $180K', description: 'Build internal developer platforms that enable teams to self-serve infrastructure and deployments.' },
    { title: 'Cloud DevOps Architect', level: 'Expert', indiaRange: '₹28 – 55 LPA', globalRange: '$160K – $220K', description: 'Design the overall cloud and automation strategy — multi-cloud, GitOps, and platform engineering.' },
    { title: 'DevSecOps Engineer', level: 'Intermediate–Expert', indiaRange: '₹14 – 30 LPA', globalRange: '$120K – $175K', description: 'Integrate security tooling into CI/CD pipelines and enforce compliance as code.' },
    { title: 'VP of Engineering / Engineering Manager', level: 'Expert (Leadership)', indiaRange: '₹40 – 90 LPA', globalRange: '$190K – $320K', description: 'Lead DevOps/Platform engineering teams, define culture, and drive organizational transformation.' },
];

const salaryTable: RoadmapSalaryRow[] = [
    { level: 'Fresher (0–1 yr)', india: '₹4 – 8 LPA', usa: '$70K – $95K', uk: '£40K – £58K', canada: 'C$70K – C$92K', australia: 'AU$75K – AU$98K' },
    { level: 'Intermediate (2–4 yr)', india: '₹10 – 22 LPA', usa: '$105K – $150K', uk: '£65K – £90K', canada: 'C$100K – C$140K', australia: 'AU$105K – AU$145K' },
    { level: 'Senior (5–8 yr)', india: '₹20 – 40 LPA', usa: '$150K – $200K', uk: '£90K – £130K', canada: 'C$140K – C$180K', australia: 'AU$145K – AU$190K' },
    { level: 'Expert / Architect (8+ yr)', india: '₹35 – 65 LPA', usa: '$180K – $270K', uk: '£120K – £175K', canada: 'C$175K – C$240K', australia: 'AU$180K – AU$250K' },
];
---

<RoadmapPage
    metaTitle={"DevOps Engineer Roadmap & Salary Guide"}
    metaDescription={"Complete DevOps Engineer career roadmap from Fresher to Expert — CI/CD, Kubernetes, Terraform, GitOps, Platform Engineering, and salary data for India and global markets."}
    accent="green"
    heroIcon={"⚙️"}
    heroTitle={"DevOps Engineer"}
    heroSubtitle={"From Git and Docker to GitOps and Platform Engineering — a complete path through CI/CD automation, Kubernetes, IaC, observability, and DevSecOps."}
    heroBadges={["CI/CD Pipelines", "Kubernetes & Helm", "Terraform & Ansible", "GitOps & SRE"]}
    jobRolesTitle={"💼 Job Roles in DevOps"}
    jobRolesIntro={"DevOps roles have evolved from generalist positions into specialized disciplines — SRE, Platform Engineering, and DevSecOps are now distinct career tracks."}
    salaryIntro={"DevOps salaries have grown rapidly — demand for automation skills outpaces supply in virtually every market."}
    salaryFootnote={"* Salary ranges are indicative, sourced from Glassdoor, LinkedIn Salary, Levels.fyi, Stack Overflow Developer Survey, and Naukri.com (2024–2025)."}
    ctaTitle={"Ready to Automate the World?"}
    levels={levels}
    jobRoles={jobRoles}
    salaryTable={salaryTable}
/>
